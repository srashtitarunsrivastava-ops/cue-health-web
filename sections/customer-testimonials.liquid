{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ch-testimonials-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<section class="ch-testimonials ch-testimonials-{{ section.id }}" data-ch-testimonials>
  <div class="ch-testimonials__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ch-testimonials__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ch-testimonials__subheading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="ch-testimonials__track-wrapper">
      <div class="ch-testimonials__track">
        {%- for block in section.blocks -%}
          <div class="ch-testimonials__card" {{ block.shopify_attributes }}>
            <div class="ch-testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- assign rating = block.settings.rating | times: 1 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  {%- render 'ch-icon', icon: 'star-filled', size: 18 -%}
                {%- else -%}
                  {%- render 'ch-icon', icon: 'star', size: 18 -%}
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if block.settings.product_name != blank -%}
              <p class="ch-testimonials__product">
                {%- render 'ch-icon', icon: 'check-simple', size: 14 -%}
                Verified purchase · {{ block.settings.product_name }}
              </p>
            {%- endif -%}

            <p class="ch-testimonials__text">"{{ block.settings.review_text }}"</p>

            <div class="ch-testimonials__author">
              <div class="ch-testimonials__avatar">
                {%- if block.settings.avatar != blank -%}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 88 }}"
                    alt="{{ block.settings.customer_name }}"
                    width="44" height="44" loading="lazy"
                  >
                {%- else -%}
                  {{ block.settings.customer_name | slice: 0 | upcase }}
                {%- endif -%}
              </div>
              <div class="ch-testimonials__author-info">
                <strong>{{ block.settings.customer_name }}</strong>
                <span>
                  {%- render 'ch-icon', icon: 'location', size: 12 -%}
                  {{ block.settings.customer_location }}
                </span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="ch-testimonials__nav">
      <button class="ch-testimonials__btn ch-testimonials__btn--prev" type="button" aria-label="Previous">
        {%- render 'ch-icon', icon: 'arrow-right', size: 18 -%}
      </button>
      <div class="ch-testimonials__dots"></div>
      <button class="ch-testimonials__btn ch-testimonials__btn--next" type="button" aria-label="Next">
        {%- render 'ch-icon', icon: 'arrow-right', size: 18 -%}
      </button>
    </div>

    <div class="ch-testimonials__summary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      <div class="ch-testimonials__summary-stars">
        {%- for i in (1..5) -%}{%- render 'ch-icon', icon: 'star-filled', size: 20 -%}{%- endfor -%}
      </div>
      <p>
        <strong>{{ section.blocks.size | times: 1 }}+ happy customers</strong> · Rated 4.9/5 on average
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Testimonials",
  "tag": "section",
  "class": "ch-testimonials-section",
  "settings": [
    { "type": "text",  "id": "heading",    "label": "Heading",    "default": "What Our Customers Say" },
    { "type": "text",  "id": "subheading", "label": "Subheading", "default": "Real results from real people across India" },
    { "type": "color", "id": "bg_color",   "label": "Background", "default": "#F8FAF9" },
    { "type": "range", "id": "padding_top",    "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding Top",    "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text",         "id": "customer_name",     "label": "Name",                "default": "Priya S." },
        { "type": "text",         "id": "customer_location", "label": "Location",            "default": "Mumbai" },
        { "type": "text",         "id": "product_name",      "label": "Product (optional)" },
        { "type": "image_picker", "id": "avatar",            "label": "Photo (optional)" },
        { "type": "range",        "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Stars", "default": 5 },
        { "type": "textarea",     "id": "review_text",       "label": "Review",              "default": "CueHealth supplements have completely transformed my energy levels. Highly recommended!" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "customer_name": "Priya S.",   "customer_location": "Mumbai",    "rating": 5, "review_text": "CueHealth supplements have completely transformed my energy levels. I feel more focused and active throughout the day. Highly recommended!" } },
        { "type": "testimonial", "settings": { "customer_name": "Rahul M.",   "customer_location": "Delhi",     "rating": 5, "review_text": "Finally found supplements that actually work! Great quality ingredients and fast delivery. Will definitely order again." } },
        { "type": "testimonial", "settings": { "customer_name": "Ananya K.",  "customer_location": "Bangalore", "rating": 5, "review_text": "The sleep supplement is a game-changer. Noticed a huge improvement in my sleep quality within the first week." } },
        { "type": "testimonial", "settings": { "customer_name": "Vikram R.",  "customer_location": "Hyderabad", "rating": 4, "review_text": "Premium quality at a fair price. Love that they're FSSAI approved and lab tested. Trust is everything with supplements." } },
        { "type": "testimonial", "settings": { "customer_name": "Neha T.",    "customer_location": "Pune",      "rating": 5, "review_text": "3 months in and I'm blown away by the results. My immunity has improved noticeably!" } }
      ]
    }
  ]
}
{% endschema %}
