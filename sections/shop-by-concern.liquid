{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ch-concerns-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="ch-concerns ch-concerns-{{ section.id }}">
  <div class="ch-concerns__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ch-concerns__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ch-concerns__subheading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="ch-concerns__grid">
      {%- for block in section.blocks -%}
        <a
          class="ch-concern-item"
          href="{{ block.settings.link | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          <div class="ch-concern-item__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 220 }}"
                alt="{{ block.settings.label }}"
                width="110" height="110" loading="lazy"
              >
            {%- else -%}
              <i class="fa-solid {{ block.settings.fa_icon }}" aria-hidden="true"></i>
            {%- endif -%}
          </div>
          <span class="ch-concern-item__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Concern",
  "tag": "section",
  "class": "ch-concerns-section",
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "Shop by Health Concern" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Find the right Ayurvedic formula for your wellness goal" },
    { "type": "range", "id": "padding_top",    "min": 20, "max": 100, "step": 4, "unit": "px", "label": "Padding Top",    "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 20, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern Category",
      "settings": [
        { "type": "text",         "id": "label",   "label": "Category Label",                "default": "Immunity" },
        { "type": "text",         "id": "fa_icon", "label": "Font Awesome Icon Class",       "info": "e.g. fa-moon, fa-shield-halved, fa-bolt (fa-solid prefix added automatically)", "default": "fa-shield-halved" },
        { "type": "image_picker", "id": "image",   "label": "Category Image (optional)" },
        { "type": "url",          "id": "link",    "label": "Collection Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Concern",
      "blocks": [
        { "type": "concern", "settings": { "label": "Sleep & Recovery", "fa_icon": "fa-moon" } },
        { "type": "concern", "settings": { "label": "Immunity",         "fa_icon": "fa-shield-halved" } },
        { "type": "concern", "settings": { "label": "Women's Health",   "fa_icon": "fa-venus" } },
        { "type": "concern", "settings": { "label": "Gut Health",       "fa_icon": "fa-leaf" } },
        { "type": "concern", "settings": { "label": "Energy & Focus",   "fa_icon": "fa-bolt" } }
      ]
    }
  ]
}
{% endschema %}
