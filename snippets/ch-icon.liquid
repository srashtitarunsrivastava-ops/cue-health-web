{% comment %}
  CueHealth Icon System — Font Awesome 6 Free
  Usage: {% render 'ch-icon', icon: 'shield', size: 18, class: 'extra-class' %}
  Size is in pixels (sets font-size). Colour inherits from parent.
{% endcomment %}
{%- assign icon_size = size | default: 18 -%}
{%- case icon -%}

  {%- when 'shield' -%}
    <i class="ch-icon fa-solid fa-shield-halved{% if class %} {{ class }}{% endif %}" style="font-size:{{ icon_size }}px;" aria-hidden="true"></i>

  {%- when 'flask' or 'lab' -%}
